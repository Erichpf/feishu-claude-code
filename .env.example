# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude 默认配置
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_CWD=~

# 工具权限模式：bypassPermissions（跳过所有确认，推荐个人使用）
#              default（需要确认敏感操作）
PERMISSION_MODE=bypassPermissions

# （可选）Claude CLI 路径，留空则自动从 PATH 查找
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# ── 代码问答助手专用配置 ──────────────────────────────────────

# 追加系统提示：约束 Claude 只做代码文档问答
# APPEND_SYSTEM_PROMPT=你是一个代码文档小助手...

# 禁止使用的工具（防止写文件）
# DISALLOWED_TOOLS=Write,Edit,NotebookEdit

# 额外允许访问的目录（让 Claude 同时能读多个仓库）
# ADD_DIRS=/path/to/another/repo

# 内置 workspace 预注册（新用户自动拥有，格式：name:path,name:path）
# BUILTIN_WORKSPACES=mai:/home/user/maimai/mai,maigo:/home/user/maimai/maigo

# 定时 git pull 更新的仓库目录（逗号分隔），留空则不自动更新
# GIT_PULL_DIRS=/home/user/maimai/mai,/home/user/maimai/maigo
# git pull 间隔（秒），默认 1800 = 30 分钟
# GIT_PULL_INTERVAL=1800
